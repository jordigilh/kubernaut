## Automation Commands

```bash
# Run test pyramid
make test                          # Unit tests
make test-integration-[service]    # Integration tests
make test-e2e-[service]            # E2E tests

# Anti-pattern detection
make lint-test-patterns            # Detect NULL-TESTING, mock overuse
./scripts/validation/check-test-anti-patterns.sh --verbose

# Business integration verification
make lint-business-integration     # Check cmd/ integration
make lint-tdd-compliance           # Check BDD framework, BR references

# Coverage standard detection
grep -rE "Integration.*(>50%|<20%|20%)" --include="*.md" --include="*_test.go" --exclude-dir="archive" .
grep -rE ">=80%" --include="*.md" --include="*_test.go" .

# Python env-var detection (ADR-030)
grep -r "os.getenv" kubernaut-agent/ --include="*.py" | grep -v "CONFIG_FILE"
```

