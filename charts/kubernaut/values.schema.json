{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kubernaut Helm Chart Values",
  "description": "Schema for validating Kubernaut Helm chart values.yaml",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "resourceQuantity": {
      "description": "Kubernetes resource quantity (e.g., 256Mi, 100m)",
      "type": "string"
    },
    "resources": {
      "description": "Kubernetes resource requests and limits",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "memory": { "$ref": "#/definitions/resourceQuantity" },
            "cpu": { "$ref": "#/definitions/resourceQuantity" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "memory": { "$ref": "#/definitions/resourceQuantity" },
            "cpu": { "$ref": "#/definitions/resourceQuantity" }
          }
        }
      }
    },
    "securityContext": {
      "description": "Kubernetes securityContext (pod or container level)",
      "type": "object"
    },
    "serviceConfig": {
      "description": "Kubernetes Service configuration",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP",
          "description": "Kubernetes Service type"
        }
      }
    },
    "nodeSelector": {
      "description": "Kubernetes node selector",
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "pdb": {
      "description": "PodDisruptionBudget configuration",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "minAvailable": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
        "maxUnavailable": { "oneOf": [{ "type": "integer" }, { "type": "string" }] }
      }
    },
    "affinity": {
      "description": "Kubernetes affinity rules",
      "type": "object"
    },
    "topologySpreadConstraints": {
      "description": "Kubernetes topology spread constraints",
      "type": "array",
      "items": { "type": "object" }
    },
    "toleration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string" },
        "operator": { "type": "string" },
        "value": { "type": "string" },
        "effect": { "type": "string" },
        "tolerationSeconds": { "type": "integer" }
      }
    },
    "tolerations": {
      "description": "Pod tolerations (overrides global.tolerations for this component)",
      "type": "array",
      "items": { "$ref": "#/definitions/toleration" }
    }
  },
  "properties": {
    "global": {
      "type": "object",
      "description": "Global settings applied across all components",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "registry": {
              "type": "string",
              "default": "quay.io",
              "description": "Container image registry hostname (e.g. quay.io, harbor.corp, image-registry.openshift-image-registry.svc:5000/ns)"
            },
            "namespace": {
              "type": "string",
              "default": "kubernaut-ai",
              "description": "Image namespace prefix. Joined to service name by separator."
            },
            "separator": {
              "type": "string",
              "enum": ["/", "-"],
              "default": "/",
              "description": "Character joining namespace to service name. Use '/' for nested registries (Harbor, Artifactory), '-' for flat registries (quay.io, Docker Hub, OCP internal)."
            },
            "tag": {
              "type": "string",
              "default": "",
              "description": "Image tag; empty defaults to Chart.appVersion"
            },
            "digest": {
              "type": "string",
              "default": "",
              "description": "Image digest (e.g. sha256:abc...); when set, overrides tag for immutable references"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent",
              "description": "Image pull policy"
            }
          }
        },
        "imagePullSecrets": {
          "type": "array",
          "default": [],
          "description": "List of image pull secret names for private registries",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            },
            "required": ["name"]
          }
        },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": {
          "type": "array",
          "items": { "$ref": "#/definitions/toleration" },
          "default": [],
          "description": "Pod tolerations"
        }
      }
    },
    "nameOverride": {
      "type": "string",
      "default": "",
      "description": "Override the chart name in resource names"
    },
    "fullnameOverride": {
      "type": "string",
      "default": "",
      "description": "Override the full resource names"
    },
    "demoContent": {
      "type": "object",
      "description": "Demo content: bundled ActionTypes and RemediationWorkflows for quickstart evaluation.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true, "description": "Deploy bundled demo ActionTypes and RemediationWorkflows." }
      }
    },
    "tls": {
      "type": "object",
      "description": "TLS certificate management for AuthWebhook. mode=hook uses self-signed certs via Helm hooks; mode=cert-manager delegates to cert-manager.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["hook", "cert-manager", "manual"],
          "default": "hook",
          "description": "TLS mode: 'hook' (self-signed via Helm hooks), 'cert-manager' (production, requires cert-manager), or 'manual' (user-managed certificates)"
        },
        "certManager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "issuerRef": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "default": "",
                  "description": "Name of the Issuer or ClusterIssuer (required when tls.mode=cert-manager)"
                },
                "kind": {
                  "type": "string",
                  "enum": ["Issuer", "ClusterIssuer"],
                  "default": "ClusterIssuer",
                  "description": "Kind of the issuer resource"
                },
                "group": {
                  "type": "string",
                  "default": "cert-manager.io",
                  "description": "API group of the issuer"
                }
              }
            }
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "description": "Gateway service (AlertManager webhook target + external signal ingestion)",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "server": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxConcurrentRequests": { "type": "integer", "default": 100 },
                "readTimeout": { "type": "string", "default": "30s" },
                "writeTimeout": { "type": "string", "default": "30s" }
              }
            },
            "deduplication": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cooldownPeriod": { "type": "string", "default": "5m" }
              }
            }
          }
        },
        "resources": { "$ref": "#/definitions/resources" },
        "service": { "$ref": "#/definitions/serviceConfig" },
        "auth": {
          "type": "object",
          "description": "BR-GATEWAY-036/037: Auth middleware configuration",
          "additionalProperties": false,
          "properties": {
            "signalSources": {
              "type": "array",
              "description": "External signal sources that need RBAC to call the Gateway",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "serviceAccount": { "type": "string" },
                  "namespace": { "type": "string" }
                }
              }
            }
          }
        },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "datastorage": {
      "type": "object",
      "description": "DataStorage service (audit trail, workflow catalog)",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "database": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sslMode": { "type": "string", "default": "disable", "description": "PostgreSQL SSL mode" },
                "maxOpenConns": { "type": "integer", "default": 100, "description": "Maximum open database connections" },
                "maxIdleConns": { "type": "integer", "default": 20, "description": "Maximum idle database connections" },
                "connMaxLifetime": { "type": "string", "default": "1h", "description": "Maximum connection lifetime" }
              }
            }
          }
        },
        "dbExistingSecret": {
          "type": "string",
          "default": "",
          "description": "DEPRECATED: db-secrets.yaml is now in postgresql-secret. Set only for BYO PostgreSQL with a separate DataStorage secret."
        },
        "resources": { "$ref": "#/definitions/resources" },
        "service": { "$ref": "#/definitions/serviceConfig" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "aianalysis": {
      "type": "object",
      "description": "AIAnalysis controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "rego": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "confidenceThreshold": {
              "oneOf": [{ "type": "number" }, { "type": "null" }],
              "description": "BR-AI-076: nil = use Rego default (0.8)"
            }
          }
        },
        "policies": {
          "type": "object",
          "description": "Approval policy externalization. Provide content via --set-file or reference an existing ConfigMap.",
          "additionalProperties": false,
          "properties": {
            "content": { "type": "string", "default": "" },
            "existingConfigMap": { "type": "string", "default": "" }
          }
        },
        "resources": { "$ref": "#/definitions/resources" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "signalprocessing": {
      "type": "object",
      "description": "SignalProcessing controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "policy": {
          "type": "string",
          "default": "",
          "description": "Raw Rego policy content (ADR-060). Inject via --set-file signalprocessing.policy=policy.rego"
        },
        "existingPolicyConfigMap": {
          "type": "string",
          "default": "",
          "description": "Pre-existing ConfigMap with key 'policy.rego'. Mutually exclusive with 'policy'."
        },
        "proactiveSignalMappings": {
          "type": "object",
          "description": "Proactive signal mappings (YAML, ADR-054). Optional.",
          "additionalProperties": false,
          "properties": {
            "content": { "type": "string", "default": "" },
            "existingConfigMap": { "type": "string", "default": "" }
          }
        },
        "resources": { "$ref": "#/definitions/resources" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "remediationorchestrator": {
      "type": "object",
      "description": "RemediationOrchestrator controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "resources": { "$ref": "#/definitions/resources" },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timeouts": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "global": { "type": "string", "default": "1h", "description": "Global remediation timeout" },
                "processing": { "type": "string", "default": "5m", "description": "Signal processing phase timeout" },
                "analyzing": { "type": "string", "default": "10m", "description": "AI analysis phase timeout" },
                "executing": { "type": "string", "default": "30m", "description": "Workflow execution phase timeout" },
                "verifying": { "type": "string", "default": "30m", "description": "Effectiveness verification phase timeout" }
              }
            },
            "routing": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "consecutiveFailureThreshold": { "type": "integer", "default": 3, "description": "Failures before cooldown" },
                "consecutiveFailureCooldown": { "type": "string", "default": "1h", "description": "Cooldown after consecutive failures" },
                "recentlyRemediatedCooldown": { "type": "string", "default": "5m", "description": "Cooldown for recently remediated signals" },
                "ineffectiveChainThreshold": { "type": "integer", "default": 3, "description": "Ineffective workflow chain length before escalation" },
                "recurrenceCountThreshold": { "type": "integer", "default": 5, "description": "Signal recurrence count before escalation" },
                "ineffectiveTimeWindow": { "type": "string", "default": "4h", "description": "Time window for ineffectiveness evaluation" }
              }
            },
            "effectivenessAssessment": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "stabilizationWindow": {
                  "type": "string",
                  "default": "5m",
                  "description": "Time for system stabilization after remediation before assessment"
                }
              }
            },
            "asyncPropagation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "gitOpsSyncDelay": {
                  "type": "string",
                  "default": "3m",
                  "description": "Expected time for GitOps tool (ArgoCD/Flux) to sync changes to cluster"
                },
                "operatorReconcileDelay": {
                  "type": "string",
                  "default": "1m",
                  "description": "Expected time for operator to reconcile after CR update"
                },
                "proactiveAlertDelay": {
                  "type": "string",
                  "default": "5m",
                  "description": "Extra delay for proactive alert resolution"
                }
              }
            },
            "notifications": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "notifySelfResolved": {
                  "type": "boolean",
                  "default": false,
                  "description": "Emit status-update notification when signal self-resolves (BR-ORCH-037 AC-037-08)"
                }
              }
            },
            "retention": {
              "type": "object",
              "additionalProperties": false,
              "description": "CRD retention TTL configuration (Issue #265)",
              "properties": {
                "period": {
                  "type": "string",
                  "default": "24h",
                  "description": "Duration before terminal RemediationRequests are cleaned up"
                }
              }
            }
          }
        },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "workflowexecution": {
      "type": "object",
      "description": "WorkflowExecution controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "execution": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cooldownPeriod": { "type": "string", "default": "1m", "description": "Cooldown between workflow executions" }
              }
            },
            "ansible": {
              "type": "object",
              "description": "AWX/AAP connectivity for the ansible executor (issue #478). Omit to disable.",
              "additionalProperties": false,
              "required": ["apiURL"],
              "properties": {
                "apiURL": { "type": "string", "minLength": 1, "description": "AWX/AAP API base URL (required when ansible is enabled)" },
                "insecure": { "type": "boolean", "default": false, "description": "Skip TLS verification for AWX API" },
                "organizationID": { "type": "integer", "default": 1, "description": "AWX organization ID" },
                "tokenSecretRef": {
                  "type": "object",
                  "description": "Reference to a K8s Secret containing the AWX API token",
                  "additionalProperties": false,
                  "required": ["name", "key"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1, "description": "Secret name" },
                    "key": { "type": "string", "default": "token", "description": "Key within the Secret" },
                    "namespace": { "type": "string", "default": "", "description": "Namespace of the Secret (empty = release namespace)" }
                  }
                }
              }
            }
          }
        },
        "workflowNamespace": {
          "type": "string",
          "description": "Namespace for Job/PipelineRun execution",
          "default": "kubernaut-workflows"
        },
        "resources": { "$ref": "#/definitions/resources" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "notification": {
      "type": "object",
      "description": "Notification controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "slack": {
          "type": "object",
          "description": "Slack quickstart shortcut. Auto-generates routing and credential projection when secretName is set.",
          "additionalProperties": false,
          "properties": {
            "secretName": { "type": "string", "default": "", "description": "K8s Secret containing Slack webhook URL. Empty = no Slack." },
            "secretKey": { "type": "string", "default": "webhook-url", "description": "Key within the Secret that holds the webhook URL." },
            "channel": { "type": "string", "default": "#kubernaut-alerts", "description": "Slack channel for notifications." }
          }
        },
        "routing": {
          "type": "object",
          "description": "Notification routing externalization. Provide content via --set-file or reference an existing ConfigMap.",
          "additionalProperties": false,
          "properties": {
            "content": { "type": "string", "default": "" },
            "existingConfigMap": { "type": "string", "default": "" }
          }
        },
        "credentials": {
          "type": "array",
          "description": "Per-receiver credentials projected into /etc/notification/credentials/",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "secretName", "secretKey"],
            "properties": {
              "name": { "type": "string" },
              "secretName": { "type": "string" },
              "secretKey": { "type": "string" }
            }
          }
        },
        "resources": { "$ref": "#/definitions/resources" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "effectivenessmonitor": {
      "type": "object",
      "description": "EffectivenessMonitor controller",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "initImage": { "type": "string", "default": "registry.access.redhat.com/ubi10/ubi-minimal:latest", "description": "Image for the wait-for-service-ca init container (Issue #484). Override for air-gapped environments." },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "assessment": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "stabilizationWindow": { "type": "string", "default": "30s", "description": "Time to wait after remediation before assessing effectiveness" },
                "validityWindow": { "type": "string", "default": "120s", "description": "Time window for assessment validity" }
              }
            }
          }
        },
        "resources": { "$ref": "#/definitions/resources" },
        "podSecurityContext": { "$ref": "#/definitions/securityContext" },
        "containerSecurityContext": { "$ref": "#/definitions/securityContext" },
        "pdb": { "$ref": "#/definitions/pdb" },
        "affinity": { "$ref": "#/definitions/affinity" },
        "topologySpreadConstraints": { "$ref": "#/definitions/topologySpreadConstraints" },
        "nodeSelector": { "$ref": "#/definitions/nodeSelector" },
        "tolerations": { "$ref": "#/definitions/tolerations" }
      }
    },
    "kubernautAgent": {
      "type": "object",
      "description": "Kubernaut Agent (Go LLM investigation service)",
      "additionalProperties": false,
      "properties": {
        "replicas": { "type": "integer", "default": 1 },
        "resources": { "$ref": "#/definitions/resources" },
        "service": { "$ref": "#/definitions/serviceConfig" },
        "llm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "credentialsSecretName": { "type": "string", "default": "llm-credentials", "description": "Name of the pre-existing K8s Secret containing LLM API credentials (e.g. OPENAI_API_KEY)" },
            "provider": { "type": "string", "default": "", "description": "Quickstart: LLM provider name (openai, anthropic). Auto-generates SDK config when set with model." },
            "model": { "type": "string", "default": "", "description": "Quickstart: LLM model name (gpt-4o, claude-sonnet-4-20250514). Auto-generates SDK config when set with provider." },
            "structuredOutput": { "type": "boolean", "default": false, "description": "Enable structured JSON output via provider-native schema enforcement." },
            "oauth2": {
              "type": "object",
              "description": "OAuth2 client credentials grant for enterprise LLM gateway authentication.",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean", "default": false, "description": "Enable OAuth2 client credentials token acquisition for LLM requests." },
                "tokenURL": { "type": "string", "default": "", "description": "OAuth2 token endpoint URL (e.g. Keycloak, Azure AD)." },
                "credentialsSecretRef": { "type": "string", "default": "", "description": "K8s Secret name containing client-id and client-secret keys." },
                "scopes": { "type": "string", "default": "", "description": "Space-separated OAuth2 scopes." }
              }
            }
          }
        },
        "sdkConfigContent": {
          "type": "string",
          "default": "",
          "description": "Raw SDK config YAML. When set (e.g. via --set-file), replaces auto-generated SDK config in the kubernaut-agent-sdk-config ConfigMap."
        },
        "existingSdkConfigMap": {
          "type": "string",
          "default": "",
          "description": "Use a pre-existing ConfigMap for SDK config instead of chart-generated. When set, kubernaut-agent-sdk-config is not created. Takes priority over sdkConfigContent."
        },
