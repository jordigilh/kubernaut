{
  "realm": "kubernaut-fleet",
  "enabled": true,
  "sslRequired": "external",
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "kubernaut-fleet-read",
      "name": "Kubernaut Fleet Read (E2E, subject identity)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "e2e-fleet-secret",
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins",
        "kube-mcp-server-audience"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    },
    {
      "clientId": "kube-mcp-server",
      "name": "kube-mcp-server (E2E, token-exchange requester)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "e2e-kube-mcp-server-secret",
      "attributes": {
        "standard.token.exchange.enabled": "true"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins",
        "k8s-api-audience"
      ]
    },
    {
      "clientId": "k8s-api",
      "name": "Kubernetes API server (E2E, token-exchange target audience)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    }
  ],
  "clientScopes": [
    {
      "name": "kube-mcp-server-audience",
      "description": "Authorizes kube-mcp-server to present this client's tokens for RFC 8693 token exchange (audience gate, validated empirically in Spike S18: removing this scope reinstates Keycloak's access_denied 'Client is not within the token audience').",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "kube-mcp-server-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "kube-mcp-server",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "k8s-api-audience",
      "description": "Scopes kube-mcp-server's exchanged tokens to k8s-api; also carries a preferred_username mapper the API server's OIDC authenticator requires (see keycloak_e2e.go).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "k8s-api-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "k8s-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "k8s-api-preferred-username-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
