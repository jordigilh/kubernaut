{
	"dashboard": {
		"title": "HolmesGPT API Service",
		"tags": [
			"kubernaut",
			"holmesgpt",
			"ai",
			"investigations"
		],
		"timezone": "browser",
		"schemaVersion": 36,
		"version": 2,
		"refresh": "30s",
		"time": {
			"from": "now-6h",
			"to": "now"
		},
		"panels": [
			{
				"title": "Overview",
				"type": "row",
				"gridPos": {
					"x": 0,
					"y": 0,
					"w": 24,
					"h": 1
				},
				"collapsed": false
			},
			{
				"title": "Requests Per Second",
				"type": "stat",
				"gridPos": {
					"x": 0,
					"y": 1,
					"w": 8,
					"h": 4
				},
				"targets": [
					{
						"expr": "sum(rate(aiagent_api_investigations_total[1m]))",
						"legendFormat": "RPS"
					}
				],
				"options": {
					"colorMode": "value",
					"graphMode": "area",
					"orientation": "auto"
				},
				"fieldConfig": {
					"defaults": {
						"unit": "reqps",
						"decimals": 2
					}
				}
			},
			{
				"title": "Success Rate",
				"type": "stat",
				"gridPos": {
					"x": 8,
					"y": 1,
					"w": 8,
					"h": 4
				},
				"targets": [
					{
						"expr": "sum(rate(aiagent_api_investigations_total{status=\"success\"}[5m])) / sum(rate(aiagent_api_investigations_total[5m])) * 100",
						"legendFormat": "Success %"
					}
				],
				"options": {
					"colorMode": "value",
					"graphMode": "area"
				},
				"fieldConfig": {
					"defaults": {
						"unit": "percent",
						"decimals": 2,
						"thresholds": {
							"mode": "absolute",
							"steps": [
								{
									"value": 0,
									"color": "red"
								},
								{
									"value": 95,
									"color": "yellow"
								},
								{
									"value": 99,
									"color": "green"
								}
							]
						}
					}
				}
			},
			{
				"title": "P95 Latency",
				"type": "stat",
				"gridPos": {
					"x": 16,
					"y": 1,
					"w": 8,
					"h": 4
				},
				"targets": [
					{
						"expr": "histogram_quantile(0.95, rate(aiagent_api_investigations_duration_seconds_bucket[5m]))",
						"legendFormat": "p95"
					}
				],
				"options": {
					"colorMode": "value",
					"graphMode": "area"
				},
				"fieldConfig": {
					"defaults": {
						"unit": "s",
						"decimals": 2,
						"thresholds": {
							"mode": "absolute",
							"steps": [
								{
									"value": 0,
									"color": "green"
								},
								{
									"value": 2.5,
									"color": "yellow"
								},
								{
									"value": 5,
									"color": "red"
								}
							]
						}
					}
				}
			},
			{
				"title": "Request Rate by Status",
				"type": "timeseries",
				"gridPos": {
					"x": 0,
					"y": 5,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum by (status) (rate(aiagent_api_investigations_total[5m]))",
						"legendFormat": "{{status}}"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "reqps"
					}
				}
			},
			{
				"title": "Latency Percentiles",
				"type": "timeseries",
				"gridPos": {
					"x": 12,
					"y": 5,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "histogram_quantile(0.50, rate(aiagent_api_investigations_duration_seconds_bucket[5m]))",
						"legendFormat": "p50"
					},
					{
						"expr": "histogram_quantile(0.95, rate(aiagent_api_investigations_duration_seconds_bucket[5m]))",
						"legendFormat": "p95"
					},
					{
						"expr": "histogram_quantile(0.99, rate(aiagent_api_investigations_duration_seconds_bucket[5m]))",
						"legendFormat": "p99"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "s"
					}
				}
			},
			{
				"title": "Token Usage",
				"type": "row",
				"gridPos": {
					"x": 0,
					"y": 13,
					"w": 24,
					"h": 1
				},
				"collapsed": false
			},
			{
				"title": "Token Count (Prompt/Completion)",
				"type": "timeseries",
				"gridPos": {
					"x": 0,
					"y": 14,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum by (type) (rate(aiagent_api_llm_token_usage_total[5m]) * 60)",
						"legendFormat": "{{type}} tokens/min"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "short"
					}
				}
			},
			{
				"title": "Token Distribution by Provider",
				"type": "timeseries",
				"gridPos": {
					"x": 12,
					"y": 14,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum by (provider, model) (rate(aiagent_api_llm_token_usage_total[5m]))",
						"legendFormat": "{{provider}}-{{model}}"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				}
			},
			{
				"title": "LLM Provider",
				"type": "row",
				"gridPos": {
					"x": 0,
					"y": 22,
					"w": 24,
					"h": 1
				},
				"collapsed": false
			},
			{
				"title": "LLM Calls by Provider",
				"type": "timeseries",
				"gridPos": {
					"x": 0,
					"y": 23,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum by (provider, model) (rate(aiagent_api_llm_calls_total[5m]))",
						"legendFormat": "{{provider}}-{{model}}"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				}
			},
			{
				"title": "LLM Call Latency (p95)",
				"type": "timeseries",
				"gridPos": {
					"x": 12,
					"y": 23,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "histogram_quantile(0.95, sum by (provider, le) (rate(aiagent_api_llm_call_duration_seconds_bucket[5m])))",
						"legendFormat": "{{provider}} p95"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "s"
					}
				}
			},
			{
				"title": "LLM Success Rate",
				"type": "timeseries",
				"gridPos": {
					"x": 0,
					"y": 31,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum by (provider) (rate(aiagent_api_llm_calls_total{status=\"success\"}[5m])) / sum by (provider) (rate(aiagent_api_llm_calls_total[5m])) * 100",
						"legendFormat": "{{provider}} success %"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "percent",
						"min": 0,
						"max": 100
					}
				}
			},
			{
				"title": "Errors",
				"type": "row",
				"gridPos": {
					"x": 0,
					"y": 39,
					"w": 24,
					"h": 1
				},
				"collapsed": false
			},
			{
				"title": "Error Rate",
				"type": "timeseries",
				"gridPos": {
					"x": 0,
					"y": 40,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum(rate(aiagent_api_investigations_total{status=\"error\"}[5m])) / sum(rate(aiagent_api_investigations_total[5m])) * 100",
						"legendFormat": "Error %"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "percent",
						"min": 0,
						"max": 100,
						"thresholds": {
							"mode": "absolute",
							"steps": [
								{
									"value": 0,
									"color": "green"
								},
								{
									"value": 1,
									"color": "yellow"
								},
								{
									"value": 5,
									"color": "red"
								}
							]
						}
					}
				}
			},
			{
				"title": "Human Review Rate",
				"type": "timeseries",
				"gridPos": {
					"x": 12,
					"y": 40,
					"w": 12,
					"h": 8
				},
				"targets": [
					{
						"expr": "sum(rate(aiagent_api_investigations_total{status=\"needs_review\"}[5m])) / sum(rate(aiagent_api_investigations_total[5m])) * 100",
						"legendFormat": "Needs Review %"
					}
				],
				"options": {
					"legend": {
						"displayMode": "list",
						"placement": "bottom"
					}
				},
				"fieldConfig": {
					"defaults": {
						"unit": "percent",
						"min": 0,
						"max": 100
					}
				}
			}
		]
	}
}
